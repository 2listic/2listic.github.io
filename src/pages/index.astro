---
import ContactSection from "@components/contactSection.astro";
import Container from "@components/container.astro";
import Features from "@components/features.astro";
import Hero from "@components/hero.astro";
import StepConnect from "@components/stepConnect.astro";
import StepSimulate from "@components/stepSimulate.astro";
import StepOptimize from "@components/stepOptimize.astro";
import SnappingElement from "@components/snappingElement.astro";
import Layout from "@layouts/Layout.astro";
import ExperienceSection from "@components/experienceSection.astro";
import WaveBackground from "@components/waveBackground.astro";
---

<Layout title="" enableScrollSnap={true}>
  <SnappingElement id="hero">
    <Hero />
  </SnappingElement>

  <WaveBackground variant="purple" size={1}/>
  <SnappingElement id="step-connect" class="bg-purple-100">
    <Container>
      <StepConnect />
    </Container>
  </SnappingElement>

  <WaveBackground variant="white" size={0.75}/>
  <SnappingElement id="step-simulate">
    <Container>
      <StepSimulate />
    </Container>
  </SnappingElement>

  <WaveBackground variant="purple" size={0.75}/>
  <SnappingElement id="step-optimize" class="bg-purple-100">
    <Container>
      <StepOptimize />
    </Container>
  </SnappingElement>

  <WaveBackground variant="white" size={0.75}/>
  <SnappingElement id="features">
    <Container>
      <Features />
    </Container>
  </SnappingElement>

  <WaveBackground variant="purple" size={1}/>
  <SnappingElement id="team" class="bg-purple-100">
    <Container>
      <ExperienceSection />
    </Container>
  </SnappingElement>

  <WaveBackground variant="white" size={0.5}/>
  <SnappingElement
    id="contact"
    isLast={true}
  >
    <Container>
      <ContactSection />
    </Container>
  </SnappingElement>
</Layout>
